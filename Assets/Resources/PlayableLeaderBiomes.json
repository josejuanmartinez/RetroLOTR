                   {
                       "characterName":  "Sauron",
                       "alignment":  1,
                       "commander":  2,
                       "agent":  0,
                       "emmissary":  0,
                       "mage":  3,
                       "race":  4,
                       "hcDescription":  "Warg Riders",
                       "lcDescription":  "Easterling Chariots",
                       "hiDescription":  "Olog-hai",
                       "liDescription":  "Orcs of Mordor",
                       "arDescription":  "Goblin Archers",
                       "maDescription":  "Haradrim Spearmen",
